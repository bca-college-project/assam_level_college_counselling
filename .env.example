# .env.example — Safe template to commit to GitHub
# Copy this to .env and fill in your real values

# ─── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_NAME=college_counselling
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ─── Email / SMTP (Gmail + App Password) ───────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM_NAME=College Admission System

# ─── App ────────────────────────────────────────────────
APP_ENV=local
COOKIE_SECURE=false
